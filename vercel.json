{
  "version": 2,
  "buildCommand": "npm run build:client",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/auto-index",
      "destination": "/api/auto-index"
    },
    {
      "source": "/api/ai/:path*",
      "destination": "/api/ai"
    },
    {
      "source": "/api/login",
      "destination": "/api/index"
    },
    {
      "source": "/api/register",
      "destination": "/api/index"
    },
    {
      "source": "/api/verify-auth",
      "destination": "/api/index"
    },
    {
      "source": "/api/pages",
      "destination": "/api/index"
    },
    {
      "source": "/api/pages/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/api/sitemap/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/api/links/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/api/logs",
      "destination": "/api/index"
    },
    {
      "source": "/api/logs/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/api/config",
      "destination": "/api/index"
    },
    {
      "source": "/api/config/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/api/gap-analyzer/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/api/generate-content",
      "destination": "/api/index"
    },
    {
      "source": "/api/automation/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/api/github/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/api/android/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/api/database/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/api/models/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/api/keywords/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/robots.txt",
      "destination": "/api/robots"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap"
    },
    {
      "source": "/api/seo-page",
      "destination": "/api/seo-page"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/((?!api/|sitemap.xml|_next/|static/|assets/|favicon.ico).*)",
      "destination": "/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "texlyonline.in"
        }
      ],
      "destination": "https://www.texlyonline.in/:path*",
      "permanent": true
    },
    {
      "source": "/tools/:path*",
      "destination": "/tool/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "ALLOWALL"
        },
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors *"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        },
        {
          "key": "Vary",
          "value": "Accept-Encoding"
        }
      ]
    },
    {
      "source": "/(.*)\\.png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=2592000, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/(.*)\\.ico",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=2592000"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/ads.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    },
    {
      "source": "/api/seo-page",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=3600, stale-while-revalidate=300"
        }
      ]
    }
  ]
}