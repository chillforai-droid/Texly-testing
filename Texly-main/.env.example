# ─── Supabase (Blog Posts के लिए — REQUIRED) ──────────────────────────────────
# Supabase Dashboard → Settings → API → Project URL & anon key
# ⚠️ Vercel में दोनों नाम से set करें: VITE_ prefix के साथ भी और बिना भी
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Sitemap (server-side) के लिए इन्हें भी set करें Vercel में:
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── AI SEO Automation (GitHub Pages Sitemap के लिए) ──────────────────────────
# Format: owner/repo (full URL नहीं)
SEO_GITHUB_REPO=chillforai-droid/Texly
SEO_GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ─── Base URL ──────────────────────────────────────────────────────────────────
BASE_URL=https://www.texlyonline.in

# ─── DevStudio AI (Free) ───────────────────────────────────────────────────────
VITE_GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# ─── DevStudio Terminal (Optional) ────────────────────────────────────────────
VITE_DEVSTUDIO_WS_URL=wss://your-app.onrender.com/terminal

# ─── Texly AI Assistant (Smart Personality System) ────────────────────────────
# Gemini Flash (free tier) — primary AI
# Get free key: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxx

